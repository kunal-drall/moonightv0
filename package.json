{
  "name": "moonight-protocol",
  "private": true,
  "scripts": {
    "dev:frontend": "turbo run dev --filter=@moonight/frontend",
    "dev:backend": "turbo run dev --filter=@moonight/backend",
    "dev:docs": "turbo run dev --filter=@moonight/docs",
    "build": "turbo run build",
    "test": "turbo run test",
    "test:contracts": "cd packages/contracts && snforge test",
    "build:contracts": "cd packages/contracts && scarb build",
    "lint": "turbo run lint",
    "deploy:testnet": "tsx scripts/deploy-contracts.ts"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "packageManager": "pnpm@10.6.5"
}
